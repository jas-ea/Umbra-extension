{
  "manifest_version": 3,
  "name": "Umbra",
  "version": "2.0.1",
  "description": "A pointer-first focus overlay that softly dims the web while preserving reading, comparison, and creation flows.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Umbra",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "commands": {
    "toggle-tab-pause": {
      "suggested_key": {
        "default": "Alt+Shift+U"
      },
      "description": "Pause or resume Umbra on the current tab"
    },
    "focus-now": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Focus the current reading block immediately"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "site-profiles.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}